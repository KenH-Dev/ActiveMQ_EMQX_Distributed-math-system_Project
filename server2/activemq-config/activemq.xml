<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans.xsd
    http://activemq.apache.org/schema/core
    http://activemq.apache.org/schema/core/activemq-core.xsd">

  <!-- Enables ${...} placeholder resolution (e.g. ${activemq.conf})
       used by the imported jetty.xml below for the web console -->
  <bean class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
    <property name="locations">
      <value>file:${activemq.conf}/credentials.properties</value>
    </property>
  </bean>

  <broker xmlns="http://activemq.apache.org/schema/core"
          brokerName="math-broker"
          dataDirectory="${activemq.data}">

    <destinationPolicy>
      <policyMap>
        <policyEntries>
          <!-- Queue for incoming math requests (S1 -> dispatcher) -->
          <policyEntry queue="math.requests"
                       producerFlowControl="true"
                       memoryLimit="64mb">
            <deadLetterStrategy>
              <individualDeadLetterStrategy
                queuePrefix="DLQ."
                useQueueForQueueMessages="true"/>
            </deadLetterStrategy>
          </policyEntry>

          <!-- Queue for results going back to S1 -->
          <policyEntry queue="math.results"
                       producerFlowControl="true"
                       memoryLimit="64mb"/>
        </policyEntries>
      </policyMap>
    </destinationPolicy>

    <managementContext>
      <managementContext createConnector="false"/>
    </managementContext>

    <persistenceAdapter>
      <kahaDB directory="${activemq.data}/kahadb"/>
    </persistenceAdapter>

    <systemUsage>
      <systemUsage>
        <memoryUsage>
          <memoryUsage percentOfJvmHeap="70"/>
        </memoryUsage>
        <storeUsage>
          <storeUsage limit="5 gb"/>
        </storeUsage>
        <tempUsage>
          <tempUsage limit="2 gb"/>
        </tempUsage>
      </systemUsage>
    </systemUsage>

    <transportConnectors>
      <!-- OpenWire — used by Java clients / activemq's own tools -->
      <transportConnector
        name="openwire"
        uri="tcp://0.0.0.0:61616?maximumConnections=500"/>

      <!-- STOMP — used by our Python services (stomp.py) -->
      <transportConnector
        name="stomp"
        uri="stomp://0.0.0.0:61613?maximumConnections=500"/>
    </transportConnectors>

    <shutdownHooks>
      <bean xmlns="http://www.springframework.org/schema/beans"
            class="org.apache.activemq.hooks.SpringContextHook"/>
    </shutdownHooks>

  </broker>

  <!-- Starts the web console (Jetty) on port 8161 -->
  <import resource="jetty.xml"/>

</beans>
